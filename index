<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Moxso — NIS2 & DORA Compliance</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@200;300;400;500;600;700;800;900&family=Roboto:wght@300;400;500&family=PT+Mono&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary: #111111;
    --secondary: #8B5CF6;
    --success: #16A34A;
    --warning: #D97706;
    --danger: #DC2626;
    --surface: #FFFFFF;
    --text: #111827;
    --text-muted: #6B7280;
    --border: #E5E7EB;
    --border-light: #F3F4F6;
    --accent-purple-light: #EDE9FE;
    --accent-purple-mid: #DDD6FE;

    --font-display: 'Montserrat', sans-serif;
    --font-body: 'Roboto', sans-serif;
    --font-mono: 'PT Mono', monospace;

    --sp-4: 4px; --sp-8: 8px; --sp-12: 12px;
    --sp-16: 16px; --sp-24: 24px; --sp-32: 32px;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    color: var(--text);
    background: var(--surface);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* ─── NAV ─── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: var(--sp-16) var(--sp-32);
    display: flex; align-items: center; justify-content: space-between;
  }
  .nav-logo {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 18px;
    letter-spacing: -0.5px;
    color: var(--primary);
  }
  .nav-logo span { color: var(--secondary); }
  .nav-cta {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.5px;
    color: var(--surface);
    background: var(--primary);
    padding: 10px 20px;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .nav-cta:hover { background: var(--secondary); }

  /* ─── HERO ─── */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding-top: 80px;
    overflow: hidden;
  }

  .hero-left {
    padding: 80px 64px 80px 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-8);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--secondary);
    background: var(--accent-purple-light);
    border: 1px solid var(--accent-purple-mid);
    padding: 6px 14px;
    border-radius: 4px;
    margin-bottom: var(--sp-32);
    width: fit-content;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.1s forwards;
  }
  .hero-kicker::before {
    content: '';
    width: 6px; height: 6px;
    background: var(--secondary);
    border-radius: 50%;
    display: inline-block;
  }

  .hero-headline {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(40px, 5vw, 64px);
    line-height: 1.05;
    letter-spacing: -2px;
    color: var(--primary);
    margin-bottom: var(--sp-24);
    opacity: 0;
    animation: fadeUp 0.6s ease 0.25s forwards;
  }
  .hero-headline em {
    font-style: normal;
    color: var(--secondary);
  }
  .hero-headline .line-through {
    text-decoration: line-through;
    color: var(--text-muted);
    font-weight: 300;
  }

  .hero-sub {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 18px;
    line-height: 1.65;
    color: #374151;
    max-width: 480px;
    margin-bottom: var(--sp-32);
    opacity: 0;
    animation: fadeUp 0.6s ease 0.4s forwards;
  }

  .hero-actions {
    display: flex;
    gap: var(--sp-12);
    align-items: center;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.55s forwards;
  }

  .btn-primary {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.3px;
    color: var(--surface);
    background: var(--primary);
    padding: 14px 28px;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.2s;
    border: 2px solid var(--primary);
  }
  .btn-primary:hover { background: var(--secondary); border-color: var(--secondary); }

  .btn-ghost {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 14px;
    color: var(--text-muted);
    text-decoration: none;
    display: flex; align-items: center; gap: 6px;
    transition: color 0.2s;
  }
  .btn-ghost:hover { color: var(--primary); }
  .btn-ghost svg { transition: transform 0.2s; }
  .btn-ghost:hover svg { transform: translateX(3px); }

  /* ─── HERO RIGHT (visual panel) ─── */
  .hero-right {
    background: var(--primary);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 60px;
    opacity: 0;
    animation: fadeIn 0.8s ease 0.3s forwards;
  }

  /* Grid background texture */
  .hero-right::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(139,92,246,0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(139,92,246,0.08) 1px, transparent 1px);
    background-size: 40px 40px;
  }
  /* Gradient fade at edges */
  .hero-right::after {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 30% 50%, rgba(139,92,246,0.15) 0%, transparent 60%);
  }

  .hero-visual-card {
    position: relative; z-index: 2;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: var(--sp-32);
    width: 100%;
    max-width: 420px;
    backdrop-filter: blur(8px);
  }

  .visual-card-header {
    display: flex; justify-content: space-between; align-items: flex-start;
    margin-bottom: var(--sp-24);
  }

  .visual-card-title {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
  }

  .visual-pill {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1px;
    color: #A7F3D0;
    background: rgba(22,163,74,0.15);
    border: 1px solid rgba(22,163,74,0.3);
    padding: 4px 10px;
    border-radius: 4px;
    text-transform: uppercase;
  }

  .visual-metric {
    margin-bottom: var(--sp-24);
  }

  .metric-number {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 56px;
    letter-spacing: -3px;
    color: #fff;
    line-height: 1;
  }
  .metric-number span {
    font-size: 28px;
    font-weight: 300;
    color: var(--secondary);
    letter-spacing: -1px;
  }

  .metric-label {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    margin-top: 4px;
  }

  .visual-divider {
    height: 1px;
    background: rgba(255,255,255,0.08);
    margin-bottom: var(--sp-24);
  }

  .visual-rows {
    display: flex; flex-direction: column; gap: var(--sp-12);
  }

  .visual-row {
    display: flex; align-items: center; gap: var(--sp-12);
  }

  .vr-icon {
    width: 32px; height: 32px;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
  }

  .vr-label {
    font-family: var(--font-body);
    font-size: 13px;
    color: rgba(255,255,255,0.7);
    flex: 1;
  }

  .vr-bar-wrap {
    width: 80px; height: 4px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    overflow: hidden;
  }
  .vr-bar {
    height: 100%;
    border-radius: 2px;
    animation: barGrow 1s ease forwards;
    transform-origin: left;
  }
  @keyframes barGrow {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  .vr-status {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.5px;
  }
  .status-ok { color: #34D399; }
  .status-warn { color: #FBBF24; }
  .status-critical { color: #F87171; }

  /* ─── REGULATION STRIP ─── */
  .reg-strip {
    background: var(--border-light);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: var(--sp-24) 80px;
    display: flex;
    align-items: center;
    gap: var(--sp-32);
  }

  .reg-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .reg-divider-v { width: 1px; height: 24px; background: var(--border); }

  .reg-tags {
    display: flex; gap: var(--sp-8); flex-wrap: wrap;
  }

  .reg-tag {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.5px;
    color: var(--text-muted);
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 6px 14px;
    border-radius: 4px;
  }

  /* ─── TAB SECTION ─── */
  .tab-section {
    padding: 96px 80px;
  }

  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--secondary);
    margin-bottom: var(--sp-16);
  }

  .section-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(28px, 4vw, 44px);
    letter-spacing: -1.5px;
    color: var(--primary);
    line-height: 1.1;
    max-width: 600px;
    margin-bottom: var(--sp-16);
  }
  .section-title em {
    font-style: normal;
    color: var(--secondary);
  }

  .section-desc {
    font-weight: 300;
    font-size: 16px;
    color: var(--text-muted);
    max-width: 540px;
    margin-bottom: 48px;
    line-height: 1.7;
  }

  /* ─── TABS ─── */
  .tabs-nav {
    display: flex;
    gap: 0;
    border-bottom: 2px solid var(--border);
    margin-bottom: 48px;
  }

  .tab-btn {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: -0.3px;
    color: var(--text-muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 16px 32px 16px 0;
    position: relative;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .tab-btn::after {
    content: '';
    position: absolute;
    bottom: -2px; left: 0; right: 32px; height: 2px;
    background: var(--secondary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .tab-btn.active { color: var(--primary); }
  .tab-btn.active::after { transform: scaleX(1); }
  .tab-btn:hover { color: var(--primary); }

  .tab-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.5px;
    padding: 3px 8px;
    border-radius: 4px;
    font-weight: 400;
  }
  .badge-nis2 {
    color: var(--secondary);
    background: var(--accent-purple-light);
    border: 1px solid var(--accent-purple-mid);
  }
  .badge-dora {
    color: var(--warning);
    background: #FEF3C7;
    border: 1px solid #FDE68A;
  }

  /* ─── TAB PANELS ─── */
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  .panel-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  /* Left — content */
  .panel-content {}

  .panel-regulation-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: var(--sp-16);
  }
  .nis2-label { color: var(--secondary); }
  .dora-label { color: var(--warning); }

  .panel-headline {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 28px;
    letter-spacing: -0.8px;
    color: var(--primary);
    line-height: 1.15;
    margin-bottom: var(--sp-16);
  }

  .panel-body {
    font-weight: 300;
    font-size: 15px;
    line-height: 1.75;
    color: #374151;
    margin-bottom: var(--sp-32);
  }

  /* Requirement blocks */
  .requirements {
    display: flex;
    flex-direction: column;
    gap: var(--sp-16);
    margin-bottom: var(--sp-32);
  }

  .req-item {
    display: flex;
    gap: var(--sp-16);
    padding: var(--sp-16);
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    transition: border-color 0.2s, box-shadow 0.2s;
    cursor: default;
  }

  .req-item:hover {
    border-color: var(--secondary);
    box-shadow: 0 4px 16px rgba(139,92,246,0.08);
  }

  .req-icon {
    width: 36px; height: 36px;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .nis2-icon-bg { background: var(--accent-purple-light); }
  .dora-icon-bg { background: #FEF3C7; }

  .req-body {}

  .req-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14px;
    color: var(--primary);
    margin-bottom: 4px;
  }

  .req-desc {
    font-size: 13px;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .req-moxso-tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.5px;
    color: var(--success);
    background: #F0FDF4;
    border: 1px solid #BBF7D0;
    padding: 3px 8px;
    border-radius: 4px;
    margin-top: var(--sp-8);
  }
  .req-moxso-tag::before {
    content: '✓';
    font-weight: 700;
  }

  /* Right — proof panel */
  .panel-proof {
    position: sticky;
    top: 100px;
  }

  .proof-card {
    background: var(--primary);
    border-radius: 12px;
    padding: var(--sp-32);
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  .proof-card::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 80% 0%, rgba(139,92,246,0.2) 0%, transparent 50%),
      linear-gradient(rgba(139,92,246,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(139,92,246,0.05) 1px, transparent 1px);
    background-size: auto, 32px 32px, 32px 32px;
  }

  .proof-card > * { position: relative; z-index: 1; }

  .proof-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: var(--sp-24);
  }

  .proof-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: -0.5px;
    color: #fff;
    margin-bottom: var(--sp-16);
    line-height: 1.3;
  }

  .proof-metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-16);
    margin-bottom: var(--sp-24);
  }

  .proof-metric {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: var(--sp-16);
  }

  .pm-number {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 32px;
    letter-spacing: -1px;
    color: #fff;
    line-height: 1;
    margin-bottom: 4px;
  }
  .pm-number sup {
    font-size: 16px;
    font-weight: 300;
    color: var(--secondary);
    letter-spacing: 0;
  }
  .pm-label {
    font-size: 11px;
    font-weight: 300;
    color: rgba(255,255,255,0.5);
    line-height: 1.4;
  }

  .proof-divider {
    height: 1px;
    background: rgba(255,255,255,0.08);
    margin-bottom: var(--sp-24);
  }

  .proof-checklist {
    display: flex;
    flex-direction: column;
    gap: var(--sp-12);
    margin-bottom: var(--sp-24);
  }

  .proof-check {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-12);
    font-size: 13px;
    font-weight: 300;
    color: rgba(255,255,255,0.75);
    line-height: 1.5;
  }

  .check-dot {
    width: 18px; height: 18px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 10px;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .nis2-dot { background: rgba(139,92,246,0.2); color: #C4B5FD; }
  .dora-dot { background: rgba(217,119,6,0.2); color: #FCD34D; }

  .proof-cta {
    display: block;
    text-align: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.5px;
    color: var(--primary);
    background: #fff;
    padding: 13px 24px;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .proof-cta:hover { background: var(--accent-purple-light); }

  /* ─── CONTRAST BLOCK ─── */
  .contrast-section {
    background: var(--border-light);
    border-top: 1px solid var(--border);
    padding: 96px 80px;
  }

  .contrast-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .contrast-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--sp-32);
    text-align: center;
  }

  .contrast-table {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    gap: 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .contrast-col {
    padding: var(--sp-32);
  }

  .contrast-col-header {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: var(--sp-24);
    padding-bottom: var(--sp-16);
    border-bottom: 1px solid var(--border);
  }
  .col-old .contrast-col-header { color: var(--text-muted); }
  .col-new .contrast-col-header { color: var(--secondary); }

  .contrast-divider-col {
    background: var(--border);
  }

  .contrast-item {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-12);
    padding: 10px 0;
    border-bottom: 1px solid var(--border-light);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.5;
  }
  .contrast-item:last-child { border-bottom: none; }

  .ci-icon-old { color: #D1D5DB; font-size: 16px; flex-shrink: 0; margin-top: 2px; }
  .ci-icon-new { color: var(--secondary); font-size: 16px; flex-shrink: 0; margin-top: 2px; }
  .col-old .contrast-item { color: var(--text-muted); }
  .col-new .contrast-item { color: var(--text); font-weight: 400; }

  /* ─── BOTTOM CTA ─── */
  .bottom-cta {
    padding: 96px 80px;
    text-align: center;
  }

  .bottom-cta-pre {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--sp-24);
  }

  .bottom-cta-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(32px, 5vw, 52px);
    letter-spacing: -2px;
    color: var(--primary);
    line-height: 1.05;
    margin-bottom: var(--sp-24);
  }
  .bottom-cta-title em {
    font-style: normal;
    color: var(--secondary);
  }

  .bottom-cta-sub {
    font-size: 16px;
    font-weight: 300;
    color: var(--text-muted);
    max-width: 480px;
    margin: 0 auto var(--sp-32);
    line-height: 1.6;
  }

  .bottom-cta-actions {
    display: flex;
    gap: var(--sp-12);
    justify-content: center;
    align-items: center;
  }

  /* ─── FOOTER ─── */
  footer {
    border-top: 1px solid var(--border);
    padding: var(--sp-24) 80px;
    display: flex;
